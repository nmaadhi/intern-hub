generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MENTOR
  INTERN
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  internId           String?   @unique
  phone              String?
  dob                DateTime?
  college            String?
  password           String
  role               Role      @default(INTERN)
  status             String    @default("ACTIVE")
  mustChangePassword Boolean   @default(true)

  cohortId String?
  cohort   Cohort? @relation("CohortInterns", fields: [cohortId], references: [id], onDelete: SetNull)

  ledCohorts Cohort[] @relation("CohortMentor")

  mentorId      String?
  mentor        User?   @relation("InternMentor", fields: [mentorId], references: [id], onDelete: SetNull)
  directInterns User[]  @relation("InternMentor")

  resetTokens PasswordResetToken[]

  createdAssignments   Assignment[]          @relation("AssignmentCreator")
  submissions          Submission[]          @relation("InternSubmissions")
  assignmentRecipients AssignmentRecipient[] @relation("AssignmentRecipientIntern")

  assignedTasks  Task[] @relation("InternTasks")
  createdTasks   Task[] @relation("MentorTasks")

  createdMeetings   Meeting[]          @relation("MentorMeetings")
  meetingRecipients MeetingRecipient[] @relation("MeetingRecipientIntern")

  createdNotes   Note[]          @relation("MentorNotes")
  noteRecipients NoteRecipient[] @relation("NoteRecipientIntern")

  createdSprints      Sprint[]     @relation("MentorSprints")
  createdSprintTasks  SprintTask[] @relation("MentorSprintTasks")
  assignedSprintTasks SprintTask[] @relation("InternSprintTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cohort {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  startDate   DateTime
  endDate     DateTime?
  status      String    @default("ACTIVE")

  mentorId String?
  mentor   User?   @relation("CohortMentor", fields: [mentorId], references: [id], onDelete: SetNull)

  interns     User[]       @relation("CohortInterns")
  assignments Assignment[]
  meetings    Meeting[]
  notes       Note[]
  sprints     Sprint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Assignment {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("ACTIVE")

  cohortId String?
  cohort   Cohort? @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("AssignmentCreator", fields: [createdById], references: [id])

  recipients  AssignmentRecipient[]
  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssignmentRecipient {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  internId     String
  intern       User       @relation("AssignmentRecipientIntern", fields: [internId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([assignmentId, internId])
  @@index([assignmentId])
  @@index([internId])
}

model Submission {
  id String @id @default(cuid())

  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  internId String
  intern   User   @relation("InternSubmissions", fields: [internId], references: [id])

  content  String?
  linkUrl  String?
  fileUrl  String?
  fileName String?
  status   String  @default("SUBMITTED")
  feedback String?

  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, internId])
  @@index([assignmentId])
  @@index([internId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO")
  dueDate     DateTime?

  assignedToId String
  assignedTo   User   @relation("InternTasks", fields: [assignedToId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("MentorTasks", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId])
  @@index([createdById])
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  meetingLink String
  scheduledAt DateTime
  duration    Int?

  createdById String
  createdBy   User   @relation("MentorMeetings", fields: [createdById], references: [id])

  cohortId String?
  cohort   Cohort? @relation(fields: [cohortId], references: [id], onDelete: SetNull)

  recipients MeetingRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([scheduledAt])
}

model MeetingRecipient {
  id        String  @id @default(cuid())
  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  internId  String
  intern    User    @relation("MeetingRecipientIntern", fields: [internId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([meetingId, internId])
  @@index([meetingId])
  @@index([internId])
}

model Note {
  id       String  @id @default(cuid())
  title    String
  content  String?
  fileUrl  String?
  fileName String?

  createdById String
  createdBy   User   @relation("MentorNotes", fields: [createdById], references: [id])

  cohortId String?
  cohort   Cohort? @relation(fields: [cohortId], references: [id], onDelete: SetNull)

  recipients NoteRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([cohortId])
}

model NoteRecipient {
  id       String @id @default(cuid())
  noteId   String
  note     Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  internId String
  intern   User   @relation("NoteRecipientIntern", fields: [internId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([noteId, internId])
  @@index([noteId])
  @@index([internId])
}

// ═══════════════════════════════════════════════════════════════
// AGILE SPRINT SYSTEM
// ═══════════════════════════════════════════════════════════════

// Sprint: time-boxed work period with full agile lifecycle
model Sprint {
  id       String @id @default(cuid())
  name     String
  goal     String?

  // Lifecycle phase — controls what UI is shown
  // PLANNING: mentor adds cards + sets story points
  // ACTIVE:   board is live, interns can move cards
  // REVIEW:   board is read-only, mentor writes summary
  // COMPLETED: archived, velocity calculated
  phase     String @default("PLANNING") // PLANNING | ACTIVE | REVIEW | COMPLETED

  startDate DateTime
  endDate   DateTime

  // Capacity = max story points the team can handle this sprint
  // Set during planning so mentor doesn't overload interns
  capacity  Int @default(0)

  // Velocity = total story points completed (set when sprint completes)
  velocity  Int @default(0)

  // Optional review notes written by mentor at end of sprint
  reviewNotes String?

  cohortId String
  cohort   Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  // Who created this sprint (admin OR mentor)
  createdById String
  createdBy   User   @relation("MentorSprints", fields: [createdById], references: [id])

  tasks     SprintTask[]
  snapshots SprintDailySnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cohortId])
  @@index([phase])
}

// SprintTask: a card on the Kanban board
model SprintTask {
  id          String  @id @default(cuid())
  title       String
  description String?

  // Story points: effort estimate using Fibonacci sequence
  // 0 = unpointed, 1 2 3 5 8 13 = effort levels
  storyPoints Int @default(0)

  status  String  @default("TODO") // TODO | IN_PROGRESS | REVIEW | DONE
  blocked Boolean @default(false)
  order   Int     @default(0)

  sprintId String
  sprint   Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("InternSprintTasks", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("MentorSprintTasks", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sprintId])
  @@index([assignedToId])
}

// SprintDailySnapshot: one row per day per sprint for the burndown chart
// Captured automatically when a card moves to DONE or at the start of each day
model SprintDailySnapshot {
  id              String   @id @default(cuid())
  sprintId        String
  sprint          Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  date            DateTime // midnight of that day

  // Points remaining = total sprint points - completed points
  remainingPoints Int
  completedPoints Int
  totalPoints     Int

  createdAt DateTime @default(now())

  // One snapshot per day per sprint
  @@unique([sprintId, date])
  @@index([sprintId])
}